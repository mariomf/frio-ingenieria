# ============================================================
# Configuracion de la base de datos self-host (Raspberry Pi)
# Copia este archivo a  .env  y rellena los valores.
# ============================================================

# Postgres
POSTGRES_DB=postgres
# Genera con:  openssl rand -hex 24
POSTGRES_PASSWORD=CAMBIA_ESTO
# Password del rol de PostgREST (login). Genera con: openssl rand -hex 24
AUTHENTICATOR_PASSWORD=CAMBIA_ESTO

# Secreto para firmar los JWT (>=32 chars). Genera con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_MINIMO_32_CARACTERES

# API keys generadas a partir de JWT_SECRET con: node scripts/gen-keys.mjs "$JWT_SECRET"
ANON_KEY=
SERVICE_ROLE_KEY=

# Hostname DDNS publico (configurado en el router OpenWrt con ddns-scripts,
# ej. DuckDNS/No-IP). Debe coincidir con el que pusiste en el Caddyfile.
DDNS_HOSTNAME=tu-subdominio.duckdns.org

# Ruta al esquema del repo (relativa a docker-compose.yml)
REPO_SUPABASE=../../supabase

# Backups (si usas HDD externo, monta el disco y apunta BACKUP_DIR ahi,
# ej. /mnt/hdd/backups)
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14
